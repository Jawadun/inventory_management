            "header": "Content-Type: application/json",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"testuser\",\n    \"password\": \"password123\",\n    \"full_name\": \"Test User\",\n    \"email\": \"test@example.com\",\n    \"department\": \"IT\",\n    \"role_id\": 2\n}"
            }
