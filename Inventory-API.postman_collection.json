{
  "info": {
    "name": "Inventory Management System",
    "description": "API collection for Inventory Management System\n\n**Base URL:** http://localhost:8080\n\n**Authentication:**\n- Most endpoints require Bearer token in Authorization header\n- Get token from /api/auth/login\n- Token format: Bearer <access_token>",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "itemId",
      "value": "",
      "type": "string"
    },
    {
      "key": "requestId",
      "value": "",
      "type": "string"
    },
    {
      "key": "issueId",
      "value": "",
      "type": "string"
    },
    {
      "key": "noticeId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "javascript",
        "exec": [
          "// Token is auto-sent via Bearer auth in collection settings",
          "// If you get 401, manually call /api/auth/refresh and update accessToken variable"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Public Endpoints",
      "item": [
        {
          "name": "Get Public Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/public/stats"
          }
        },
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/public/dashboard"
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": "Content-Type: application/json",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"newuser\",\n    \"password\": \"password123\",\n    \"full_name\": \"New User\",\n    \"email\": \"user@example.com\",\n    \"department\": \"IT\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": "Content-Type: application/json",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "javascript",
                "exec": [
                  "if (pm.response.json().access_token) {",
                  "    pm.variables.set('accessToken', pm.response.json().access_token);",
                  "    pm.variables.set('refreshToken', pm.response.json().refresh_token);",
                  "    pm.variables.set('userId', pm.response.json().user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/refresh",
            "header": "Content-Type: application/json",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refresh_token\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout",
            "header": "Content-Type: application/json",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refresh_token\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "User (Self)",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/users/update",
            "header": "Content-Type: application/json",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"full_name\": \"Updated Name\",\n    \"email\": \"updated@example.com\",\n    \"department\": \"HR\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/users/password",
            "header": "Content-Type: application/json",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"old_password\": \"oldpassword\",\n    \"new_password\": \"newpassword123\"\n}"
            }
          }
        }
      ]
    },
